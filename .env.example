API_KEY=change-me-to-a-random-string

# Negotiation policy (optional; defaults shown)
# Broker pays up to listed_rate * (1 + margin)
NEGOTIATION_MAX_MARGIN=0.15
# Max counter-offers before walking away
NEGOTIATION_MAX_ROUNDS=3

# FMCSA QCMobile API key (for the /carriers/verify wrapper)
FMCSA_API_KEY=your-fmcsa-webkey

# HTTPS / reverse proxy (Caddy). Use nip.io to get real Let's Encrypt certs
# against a bare IP (replace with your server IP, dashes instead of dots).
# Requires ports 80 and 443 reachable on the host.
API_DOMAIN=api.195-35-16-20.nip.io
DASH_DOMAIN=dash.195-35-16-20.nip.io
ACME_EMAIL=you@example.com
