# nginx reverse proxy for the FDE stack on a shared host (nginx already owns
# :80/:443). Forwards two nip.io subdomains to the published container ports.
# TLS lines (listen 443 / ssl_certificate) are added automatically by:
#   sudo certbot --nginx -d api.<ip>.nip.io -d dash.<ip>.nip.io
#
# Replace 195-35-16-20 with your server IP (dashes instead of dots).

# --- API (consumed by HappyRobot) ---
server {
    listen 80;
    listen [::]:80;
    server_name api.195-35-16-20.nip.io;

    location / {
        proxy_pass http://127.0.0.1:8010;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# --- Dashboard (Streamlit — needs websocket upgrade) ---
server {
    listen 80;
    listen [::]:80;
    server_name dash.195-35-16-20.nip.io;

    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }
}
